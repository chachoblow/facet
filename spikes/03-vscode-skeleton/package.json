{
  "name": "spike-03-vscode-skeleton",
  "displayName": "Facet Spike 3 — VS Code skeleton",
  "description": "Minimal CustomTextEditorProvider used to verify VS Code integration plumbing before any editor library is layered on top.",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "facet.spike3.markdownEditor",
        "displayName": "Facet Spike 3 (Markdown)",
        "selector": [
          { "filenamePattern": "*.md" }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p ."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.6.0"
  }
}
