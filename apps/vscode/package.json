{
  "name": "@facet/vscode-extension",
  "displayName": "Facet",
  "description": "Markdown editing experience for shared alignment across humans, AI agents, and future-self.",
  "version": "0.0.0",
  "private": true,
  "publisher": "facet",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=24"
  },
  "main": "./dist/extension.js",
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "facet.markdownEditor",
        "displayName": "Facet",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@facet/core": "workspace:*",
    "codemirror": "^6.0.2"
  }
}
