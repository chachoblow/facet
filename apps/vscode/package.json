{
  "name": "@facet/vscode-extension",
  "displayName": "Facet",
  "description": "Markdown editing experience for shared alignment across humans, AI agents, and future-self.",
  "version": "0.0.0",
  "private": true,
  "publisher": "facet",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=24"
  },
  "main": "./dist/extension.js",
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onCommand:facet.setAsDefaultMarkdownEditor",
    "onCommand:facet.restoreDefaultMarkdownEditor",
    "onCommand:facet.viewSource"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "facet.markdownEditor",
        "displayName": "Facet",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "facet.setAsDefaultMarkdownEditor",
        "title": "Facet: Set as default markdown editor",
        "category": "Facet"
      },
      {
        "command": "facet.restoreDefaultMarkdownEditor",
        "title": "Facet: Restore default markdown editor",
        "category": "Facet"
      },
      {
        "command": "facet.viewSource",
        "title": "Facet: View source",
        "category": "Facet"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@facet/core": "workspace:*",
    "@shikijs/engine-javascript": "4.0.2",
    "@shikijs/langs": "4.0.2",
    "@shikijs/themes": "4.0.2",
    "codemirror": "^6.0.2",
    "mermaid": "^11.4.0",
    "shiki": "^4.0.2"
  }
}
